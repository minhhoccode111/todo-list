{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch main application",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/cmd/app",
      "args": ["-tags", "migrate"],
      "env": {
        "APP_NAME": "todo-list",
        "APP_VERSION": "1.0.0",
        "CACHE_MAX_COST": "10000",
        "CACHE_TTL": "5m",
        "CORS_ALLOW_CREDENTIALS": "true",
        "CORS_ALLOW_HEADERS": "Origin,X-Requested-With,Content-Type,Accept,Authorization",
        "CORS_ALLOW_METHODS": "GET,POST,HEAD,PUT,DELETE,PATCH",
        "CORS_ALLOW_ORIGINS": "http://localhost:3000,https://minhhoccode111.github.io",
        "HTTP_PORT": "8080",
        "JWT_EXPIRATION": "1m",
        "JWT_ISSUER": "todo-list",
        "JWT_SECRET": "d5a87dda-9967-4d97-8abe-331bfa18c7e1",
        "LOG_LEVEL": "debug",
        "METRICS_ENABLED": "true",
        "PG_POOL_MAX": "2",
        "PG_URL": "postgres://user:password@localhost:5432/db",
        "RATE_LIMIT_BURST": "20",
        "RATE_LIMIT_RPS": "10",
        "REFRESH_TOKEN_EXPIRATION": "168h",
        "REFRESH_TOKEN_SECURE": "false",
        "SWAGGER_ENABLED": "true"
      }
    }
  ]
}
