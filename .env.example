# App
APP_NAME=todo-list
APP_VERSION=1.0.0
# Cache
CACHE_MAX_COST=10000
CACHE_TTL=5m
# CORS
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_HEADERS=Origin,X-Requested-With,Content-Type,Accept,Authorization
CORS_ALLOW_METHODS=GET,POST,HEAD,PUT,DELETE,PATCH
CORS_ALLOW_ORIGINS=http://localhost:3000,https://example.com
# HTTP settings
HTTP_PORT=8080
# Logger
LOG_LEVEL=debug
# Metrics
METRICS_ENABLED=true
# PG
PG_POOL_MAX=2
PG_URL=postgres://user:password@localhost:5432/db
# RateLimit
RATE_LIMIT_BURST=20
RATE_LIMIT_RPS=10
# Swagger
SWAGGER_ENABLED=true
